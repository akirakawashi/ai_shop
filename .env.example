# Все поля необязательны: каждая секция имеет валидируемые defaults
# в соответствующем BaseSettings-классе из people_monitor/config/.

# Camera (CameraConfig, env_prefix="CAMERA_")
CAMERA_ID=shop-entrance
CAMERA_SOURCE=test.mp4
# auto | file | device | stream | screen
CAMERA_SOURCE_KIND=auto

# Захват экрана (source_kind=screen): монитор (1 — основной), необязательный
# регион [left, top, width, height] и целевая частота захвата.
CAMERA_SCREEN_MONITOR=1
# CAMERA_SCREEN_REGION=[0,0,1280,720]
CAMERA_SCREEN_FPS=15.0

CAMERA_STREAM_OPEN_TIMEOUT_MILLISECONDS=10000
CAMERA_STREAM_READ_TIMEOUT_MILLISECONDS=10000
CAMERA_RECONNECT_ATTEMPTS=5
CAMERA_RECONNECT_BACKOFF_SECONDS=1.0
CAMERA_RECONNECT_MAX_BACKOFF_SECONDS=30.0

# YOLO / tracker (ModelConfig, env_prefix="MODEL_")
MODEL_WEIGHTS=yolov8n.pt
MODEL_CONFIDENCE=0.35
MODEL_TRACKER=bytetrack.yaml
MODEL_CLASS_ID=0
MODEL_IMAGE_SIZE=640
MODEL_IOU_THRESHOLD=0.7
# MODEL_DEVICE=cpu
MODEL_VERBOSE=false

# ROI (RoiConfig): маленькая тестовая зона в центре кадра.
# Точки задаются по часовой или против часовой стрелки в диапазоне [0, 1].
ROI_POINTS=[[0.40,0.35],[0.60,0.35],[0.60,0.75],[0.40,0.75]]

# Queue occupancy state machine (EventConfig, env_prefix="EVENT_").
# Вместимость 1 предназначена для первого end-to-end теста.
EVENT_ROI_CAPACITY=1
EVENT_FULL_CONFIRM_FRAMES=5
EVENT_RECOVERY_CONFIRM_FRAMES=10
EVENT_COOLDOWN_SECONDS=60.0

# Асинхронная доставка независимо от выбранного notifier
# (NotificationConfig, env_prefix="NOTIFICATION_").
NOTIFICATION_QUEUE_SIZE=100
NOTIFICATION_DRAIN_TIMEOUT_SECONDS=15.0
NOTIFICATION_NOTIFIER_CLOSE_TIMEOUT_SECONDS=5.0
NOTIFICATION_DRAIN_ON_SHUTDOWN=true
NOTIFICATION_ALERT_MESSAGE="⚠️ Откройте вторую кассу"

# Telegram (TelegramConfig, env_prefix="TELEGRAM_")
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_API_BASE_URL=https://api.telegram.org
TELEGRAM_PROXY_URL=
TELEGRAM_TIMEOUT_SECONDS=10.0
TELEGRAM_MAX_RETRIES=2
TELEGRAM_RETRY_BACKOFF_SECONDS=0.5
TELEGRAM_SEND_SNAPSHOT=true
TELEGRAM_SNAPSHOT_FILENAME=queue-full.jpg

# Output (OutputConfig, env_prefix="OUTPUT_")
OUTPUT_ANNOTATED_VIDEO=output/roi_monitor.mp4
OUTPUT_EVENTS_FILE=output/events.jsonl
OUTPUT_SNAPSHOTS_DIR=output/events
OUTPUT_SAVE_ANNOTATED_VIDEO=true
OUTPUT_SAVE_SNAPSHOTS=true
OUTPUT_VIDEO_CODEC=mp4v
OUTPUT_JPEG_EXTENSION=.jpg
OUTPUT_JPEG_QUALITY=90

# Visualization: BGR-цвета задаются JSON-массивами
# (VisualizationConfig, env_prefix="VISUALIZATION_").
VISUALIZATION_ROI_COLOR=[0,215,255]
VISUALIZATION_INSIDE_COLOR=[0,190,0]
VISUALIZATION_OUTSIDE_COLOR=[128,128,128]
VISUALIZATION_ROI_THICKNESS=2
VISUALIZATION_BBOX_THICKNESS=2
VISUALIZATION_EVENT_BBOX_THICKNESS=4
VISUALIZATION_TEXT_THICKNESS=2
VISUALIZATION_ROI_FONT_SCALE=0.7
VISUALIZATION_BBOX_FONT_SCALE=0.55
VISUALIZATION_LABEL_VERTICAL_OFFSET=8
VISUALIZATION_MINIMUM_LABEL_Y=20
VISUALIZATION_ROI_LABEL_TEMPLATE="QUEUE {people_count}/{capacity} | {queue_state}"
VISUALIZATION_UNKNOWN_TRACK_LABEL=?
VISUALIZATION_INSIDE_STATE_LABEL=IN
VISUALIZATION_OUTSIDE_STATE_LABEL=OUT
VISUALIZATION_BBOX_LABEL_TEMPLATE="ID {track_id} | {roi_state}"

# Runtime (RuntimeConfig, env_prefix="RUNTIME_")
RUNTIME_FALLBACK_FPS=25.0
RUNTIME_LOG_LEVEL=INFO
RUNTIME_LOG_FORMAT="%(asctime)s | %(levelname)s | %(name)s | %(message)s"
